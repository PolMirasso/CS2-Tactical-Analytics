# CS2 Tactical Analytics - environment template. Copy to .env and adjust.


# Required

# JWT signing secret - generate a long random string (code default is insecure).
CS2_JWT_SECRET=change-me-to-a-long-random-string

# First admin, auto-created on startup. Both must be set or no admin is created;
# there is no hardcoded default. Use a real password outside local dev.
CS2_BOOTSTRAP_ADMIN_EMAIL=admin@cs2.local
CS2_BOOTSTRAP_ADMIN_PASSWORD=change-me

# Postgres connection for the app. Compose overrides the host to `db`; use
# localhost when running uvicorn directly.
CS2_DB_URL=postgresql+psycopg://cs2:cs2_dev_password@localhost:5432/cs2

# Credentials for the postgres container (read by docker compose, not the app).
POSTGRES_USER=cs2
POSTGRES_PASSWORD=cs2_dev_password
POSTGRES_DB=cs2

# FlareSolverr endpoint - required for HLTV /results + demo download.
# Use the compose service name in Docker, or http://localhost:8191 locally.
CS2_FLARESOLVERR_URL=http://flaresolverr:8191

# Optional overrides (defaults shown)

#CS2_DEBUG=false
#CS2_APP_NAME=CS2 Tactical Analytics API

#CS2_JWT_ALGORITHM=HS256
#CS2_JWT_EXPIRE_MINUTES=1440

#CS2_HLTV_BASE_URL=https://www.hltv.org
#CS2_REQUEST_DELAY_S=1.5
#CS2_REQUEST_TIMEOUT_S=30.0
# GOTV .rar archives are ~1 GB/match, so the binary download needs a generous timeout.
#CS2_DEMO_DOWNLOAD_TIMEOUT_S=600.0

#CS2_USE_SAMPLE_DATA=false
#CS2_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
