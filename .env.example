# Compose-level config for the root docker-compose.yml. Copy to .env.
# These feed variable interpolation in the compose file (NOT the backend app).
# Backend application secrets (CS2_JWT_SECRET, admin, FlareSolverr, …) live in
# backend/.env and are loaded into the api container via env_file.

# Postgres credentials (used by the db container and the api's CS2_DB_URL).
POSTGRES_USER=cs2
POSTGRES_PASSWORD=cs2_dev_password
POSTGRES_DB=cs2

# Baked into the frontend build / dev server. Point it at the host-exposed API.
VITE_API_BASE_URL=http://localhost:8000
